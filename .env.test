# Изолированное окружение для интеграционных тестов (tests/api/), запускаемых
# с хоста через TestClient — Postgres/Redis нужны по адресу localhost и на
# отдельных портах/с отдельным именем проекта, чтобы не пересекаться с dev-
# окружением, поднятым через обычный `docker compose up`. Используется через
# `make test` (см. Makefile), не через `docker compose up` напрямую.

# Postgres
POSTGRES_USER=space_test
POSTGRES_PASSWORD=space_test
POSTGRES_DB=space_coordinates_test
POSTGRES_PORT=55432
POSTGRES_HOST=localhost

# Redis
REDIS_PORT=56379
REDIS_HOST=localhost

# App (не используется тестами напрямую — TestClient обращается к приложению
# in-process, не по сети, — но переменная интерполируется в docker-compose.yml
# для сервиса app, даже если сам сервис не поднимается в make test)
APP_PORT=58000

RATE_LIMIT_PER_MINUTE=60
