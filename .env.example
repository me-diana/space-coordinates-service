# Скопируй в .env и подставь реальные значения. .env в git не попадает.

# Postgres
POSTGRES_USER=space
POSTGRES_PASSWORD=change-me
POSTGRES_DB=space_coordinates
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# App
APP_PORT=8000

# Rate limit на POST /v1/calculate (самый дорогой по CPU эндпоинт — см.
# docs/concurrency_notes.md). 60/мин — консервативный дефолт для одиночного
# клиента/интеграции в прототипе, не результат нагрузочного тестирования;
# подбирается под реальный профиль нагрузки при вводе в эксплуатацию.
RATE_LIMIT_PER_MINUTE=60
